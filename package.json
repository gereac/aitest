{
  "name": "cloudflare-ai-ui-app",
  "version": "1.0.0",
  "private": true,
  "description": "Bundled React UI powered by Cloudflare Workers AI",
  "type": "module",
  "scripts": {
    "build": "vite build",
    "dev": "npm run build && wrangler dev",
    "dev:client:watch": "vite build --watch",
    "dev:worker": "wrangler dev",
    "dev:split": "npm run build",
    "dev:all": "npm run dev:split && concurrently -k -n client,worker -c cyan,green \"npm run dev:client:watch\" \"npm run dev:worker\"",
    "deploy": "npm run build && wrangler deploy",
    "preview": "vite preview"
  },
  "dependencies": {
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  },
  "devDependencies": {
    "@vitejs/plugin-react": "^4.3.4",
    "concurrently": "^9.2.1",
    "vite": "^6.4.2",
    "wrangler": "^4.11.1"
  }
}
